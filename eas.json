{
  "cli": {
    "version": ">= 5.6.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "autoIncrement": true
      },
      "ios": {
        "buildType": "simulator",
        "simulator": true
      }
    },
    "preview2": {
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
